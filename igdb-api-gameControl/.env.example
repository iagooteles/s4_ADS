TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Passo 3 – Firestore (escolha um modo de autenticação)
# Caminho REAL para o .json baixado (Gerar nova chave privada). Exemplo:
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/meu-projeto-firebase-adminsdk-xxxxx.json
FIREBASE_SERVICE_ACCOUNT_PATH=
# Opcional: nome da coleção (padrão: games)
FIRESTORE_COLLECTION=


# Alternativa: variável padrão do Google (caminho absoluto para o mesmo JSON)
# GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\para\serviceAccount.json
